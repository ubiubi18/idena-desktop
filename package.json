{
  "name": "idena-desktop",
  "productName": "Idena",
  "version": "0.0.1",
  "main": "main/index.js",
  "repository": "idena-network/idena-desktop",
  "license": "MIT",
  "engines": {
    "node": ">=24.15.0 <25",
    "npm": ">=11.12.0"
  },
  "scripts": {
    "preinstall": "node scripts/check-runtime-install.js",
    "postinstall": "node scripts/rebuild-electron-runtime-deps.js",
    "start": "dotenv -e .env.local node scripts/start-electron-dev.js",
    "build": "node scripts/run-next-static-build.js",
    "dist": "npm run build && node scripts/run-electron-builder.js",
    "dist:win": "npm run build && node scripts/run-electron-builder.js --win --publish onTag",
    "dist:mac": "npm run build && node scripts/run-electron-builder.js --mac --publish onTag",
    "dist:mac:arm64": "npm run build && node scripts/run-electron-builder.js --mac --arm64 --publish onTag",
    "dist:mac:universal": "npm run build && node scripts/run-electron-builder.js --mac --universal --publish onTag",
    "dist:linux": "npm run build && node scripts/run-electron-builder.js --linux --publish onTag",
    "pack": "npm run build && node scripts/run-electron-builder.js --dir",
    "pack:mac:arm64": "npm run build && node scripts/run-electron-builder.js --dir --mac --arm64",
    "pack:mac:universal": "npm run build && node scripts/run-electron-builder.js --dir --mac --universal",
    "clean": "node scripts/clean-paths.js renderer/out renderer/.next dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "i18n:init": "npm run i18n:clean && npm run i18n:scan",
    "i18n:scan": "i18next-scanner",
    "i18n:clean": "node scripts/clean-paths.js locales/en locales/id locales/fr locales/de locales/es locales/ru locales/zh locales/ko locales/hr locales/hi locales/ro locales/uk locales/sr locales/it locales/pt locales/pl locales/si locales/tr locales/bg locales/sv locales/ja locales/el",
    "e2e": "node scripts/e2e-disabled.js"
  },
  "build": {
    "appId": "io.idena",
    "artifactName": "idena-client-${os}-${version}.${ext}",
    "npmRebuild": false,
    "files": [
      "**/*",
      "!**/.env",
      "!**/.env.*",
      "!**/*.log",
      "!.tmp",
      "!.tmp/**",
      "!tmp",
      "!tmp/**",
      "!data",
      "!data/**",
      "!logs",
      "!logs/**",
      "!coverage",
      "!coverage/**",
      "!.nyc_output",
      "!.nyc_output/**",
      "!downloads",
      "!downloads/**",
      "!renderer",
      "renderer/out"
    ],
    "protocols": {
      "name": "idena",
      "schemes": [
        "dna"
      ]
    },
    "win": {
      "publish": [
        "github"
      ],
      "icon": "main/static/icons/icon_512_2x.ico"
    },
    "mac": {
      "publish": [
        "github"
      ],
      "icon": "main/static/icons/icon-512@2x.icns"
    },
    "linux": {
      "target": [
        "deb"
      ],
      "publish": [
        "github"
      ],
      "icon": "main/static/icons/icon-512@2x.icns",
      "maintainer": "Idena <info@idena.io> (https://idena.io/)"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.6.0",
    "@electron/rebuild": "^4.0.4",
    "@testing-library/react": "^9.1.4",
    "babel-eslint": "^10.0.1",
    "babel-jest": "^29.7.0",
    "cors": "^2.8.5",
    "dotenv-cli": "3.1.0",
    "electron": "41.3.0",
    "electron-builder": "^26.8.2",
    "eslint": "^8.36.0",
    "eslint-config-wesbos": "^3.2.3",
    "i18next-scanner": "^2.10.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react-dom": "^16.8.4"
  },
  "dependencies": {
    "@chakra-ui/react": "^1.0.0",
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "@react-hook/hover": "^4.0.0",
    "@toast-ui/react-image-editor": "^1.2.0",
    "@xstate/react": "^3.2.1",
    "ansi-to-react": "^6.0.5",
    "axios": "^1.13.2",
    "canvas-confetti": "^1.4.0",
    "color-convert": "^2.0.1",
    "dayjs": "^1.9.6",
    "dequal": "^1.0.0",
    "dexie": "^3.2.2",
    "electron-store": "^3.2.0",
    "electron-updater": "^6.8.3",
    "express": "^4.17.1",
    "extract-colors": "^1.1.22",
    "framer-motion": "^4.0.0",
    "fs-extra": "^8.1.0",
    "google-protobuf": "^3.14.0",
    "i18next": "^19.0.1",
    "idena-sdk-js": "^0.1.0",
    "jimp": "^0.9.6",
    "leveldown": "^5.6.0",
    "levelup": "^4.4.0",
    "lowdb": "^1.0.0",
    "macos-version": "^5.2.1",
    "mousetrap": "^1.6.3",
    "multiformats": "^9.7.1",
    "nanoid": "^3.3.11",
    "next": "^9.5.1",
    "next-google-fonts": "^1.2.1",
    "pino": "^5.13.2",
    "prettier": "^2.8.7",
    "progress-stream": "^2.0.0",
    "qrcode.react": "^0.9.3",
    "react": "^16.8.4",
    "react-beautiful-dnd": "^10.0.4",
    "react-i18next": "^11.2.5",
    "react-query": "^3.39.0",
    "react-scroll": "^1.8.7",
    "react-swipeable": "^7.0.0",
    "reverse-line-reader": "^0.2.6",
    "rlp": "^2.2.2",
    "semver": "^7.7.2",
    "stackblur-canvas": "^2.5.0",
    "subleveldown": "^5.0.1",
    "tree-kill": "^1.2.2",
    "url-regex-safe": "^3.0.0",
    "xstate": "^4.37.1"
  },
  "overrides": {
    "@babel/runtime": "^7.26.10",
    "@babel/runtime-corejs3": "^7.26.10",
    "@tootallnate/once": "^3.0.1",
    "braces": "^3.0.3",
    "browserslist": "^4.26.3",
    "elliptic": {
      ".": "^6.6.1",
      "bn.js": "4.12.3"
    },
    "loader-utils": "^2.0.4",
    "minimatch": "^3.1.5",
    "node-fetch": "^2.7.0",
    "object-path": "^0.11.8",
    "secp256k1": "^5.0.1",
    "serialize-javascript": "^7.0.5",
    "shell-quote": "^1.8.3",
    "tar": "^7.5.13",
    "terser": "^4.8.1",
    "tui-image-editor": "3.15.3"
  },
  "prettier": {
    "trailingComma": "es5",
    "semi": false,
    "singleQuote": true,
    "bracketSpacing": false
  }
}
