{
  "name": "idena-desktop",
  "productName": "Idena",
  "version": "0.0.1",
  "description": "Desktop client for the Idena network.",
  "author": "Idena Network",
  "main": "main/index.js",
  "repository": "ubiubi18/idena-desktop",
  "license": "MIT",
  "engines": {
    "node": ">=24.18.0 <25",
    "npm": ">=11.16.0"
  },
  "scripts": {
    "preinstall": "node scripts/check-runtime-install.js",
    "start": "node --env-file-if-exists=.env.local scripts/start-electron-dev.js",
    "build": "npm run build:renderer",
    "dist": "npm run prepare:node && npm run build && node scripts/run-electron-builder.js",
    "dist:win": "npm run build:node:win:x64 && npm run build && node scripts/run-electron-builder.js --win --publish onTag",
    "dist:mac": "npm run prepare:node && npm run build && node scripts/run-electron-builder.js --mac --publish onTag",
    "dist:mac:arm64": "npm run build:node:mac:arm64 && npm run build && node scripts/run-electron-builder.js --mac --arm64 --publish onTag",
    "dist:mac:universal": "npm run prepare:node && npm run build && node scripts/run-electron-builder.js --mac --universal --publish onTag",
    "dist:linux": "npm run prepare:node && npm run build && node scripts/run-electron-builder.js --linux --publish onTag",
    "pack": "npm run prepare:node && npm run build && node scripts/run-electron-builder.js --dir",
    "pack:mac:arm64": "npm run build:node:mac:arm64 && npm run build && node scripts/run-electron-builder.js --dir --mac --arm64",
    "pack:mac:universal": "npm run prepare:node && npm run build && node scripts/run-electron-builder.js --dir --mac --universal",
    "clean": "node scripts/clean-paths.js renderer/out renderer/.next dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "i18n:init": "npm run i18n:clean && npm run i18n:scan",
    "i18n:scan": "i18next-scanner",
    "i18n:clean": "node scripts/clean-paths.js locales/en locales/id locales/fr locales/de locales/es locales/ru locales/zh locales/ko locales/hr locales/hi locales/ro locales/uk locales/sr locales/it locales/pt locales/pl locales/si locales/tr locales/bg locales/sv locales/ja locales/el",
    "e2e": "node scripts/e2e-smoke.js",
    "setup:sources": "node scripts/setup-sources.js",
    "update:sources": "node scripts/setup-sources.js --update",
    "prepare:node": "node scripts/prepare-bundled-node.js",
    "build:node": "node scripts/build-node-from-sources.js",
    "build:node:win:x64": "npm run setup:sources && node scripts/build-node-from-sources.js build/node/current/idena-go.exe --platform win32 --arch x64",
    "build:node:mac:x64": "npm run setup:sources && node scripts/build-node-from-sources.js build/node/current/idena-go --platform darwin --arch x64",
    "build:node:mac:arm64": "npm run setup:sources && node scripts/build-node-from-sources.js build/node/current/idena-go --platform darwin --arch arm64",
    "build:renderer": "node scripts/run-next-static-build.js",
    "audit:privacy": "node scripts/check-release-privacy.js",
    "audit:metadata": "node scripts/check-release-metadata.js",
    "audit:artifacts": "node scripts/check-release-artifacts.js",
    "audit:deps": "node scripts/check-dependency-footprint.js",
    "audit:electron": "node scripts/check-electron-safety.js",
    "release:check": "node scripts/release-check.js"
  },
  "build": {
    "appId": "io.idena",
    "artifactName": "idena-client-${os}-${version}.${ext}",
    "npmRebuild": false,
    "files": [
      "**/*",
      "!**/.env",
      "!**/.env.*",
      "!**/*.log",
      "!**/*.test.js",
      "!**/*.test.jsx",
      "!.github",
      "!.github/**",
      "!scripts",
      "!scripts/**",
      "!.tmp",
      "!.tmp/**",
      "!tmp",
      "!tmp/**",
      "!data",
      "!data/**",
      "!logs",
      "!logs/**",
      "!vendor",
      "!vendor/**",
      "!build",
      "!build/**",
      "!idena-go",
      "!idena-go/**",
      "!idena-wasm",
      "!idena-wasm/**",
      "!idena-wasm-binding",
      "!idena-wasm-binding/**",
      "!test",
      "!test/**",
      "!coverage",
      "!coverage/**",
      "!.nyc_output",
      "!.nyc_output/**",
      "!downloads",
      "!downloads/**",
      "!renderer",
      "renderer/out"
    ],
    "protocols": {
      "name": "idena",
      "schemes": [
        "dna"
      ]
    },
    "win": {
      "publish": [
        "github"
      ],
      "icon": "main/static/icons/icon_512_2x.ico",
      "extraResources": [
        {
          "from": "build/node/current",
          "to": "node"
        }
      ]
    },
    "mac": {
      "publish": [
        "github"
      ],
      "icon": "main/static/icons/icon-512@2x.icns",
      "extraResources": [
        {
          "from": "build/node/current",
          "to": "node"
        }
      ]
    },
    "linux": {
      "target": [
        "deb"
      ],
      "publish": [
        "github"
      ],
      "icon": "main/static/icons/icon-512@2x.icns",
      "maintainer": "Idena <info@idena.io> (https://idena.io/)",
      "extraResources": [
        {
          "from": "build/node/current",
          "to": "node"
        }
      ]
    }
  },
  "devDependencies": {
    "electron": "43.1.0",
    "electron-builder": "^26.8.2",
    "eslint": "^8.36.0",
    "eslint-config-wesbos": "^3.2.3",
    "i18next-scanner": "^2.10.3",
    "jest": "^29.7.0",
    "next": "^16.2.10",
    "prettier": "^2.8.8",
    "react-dom": "^18.2.0"
  },
  "dependencies": {
    "@chakra-ui/react": "^1.0.0",
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@react-hook/hover": "^4.0.0",
    "@xstate/react": "^3.2.1",
    "ansi-to-react": "^6.2.6",
    "axios": "^1.13.2",
    "buffer": "^6.0.3",
    "canvas-confetti": "^1.4.0",
    "color-convert": "^2.0.1",
    "dayjs": "^1.9.6",
    "dequal": "^1.0.0",
    "dexie": "^3.2.2",
    "electron-updater": "^6.8.3",
    "extract-colors": "^1.1.22",
    "framer-motion": "^4.0.0",
    "fs-extra": "^8.1.0",
    "google-protobuf": "^3.14.0",
    "i18next": "^19.0.1",
    "leveldown": "^6.1.1",
    "levelup": "^5.1.1",
    "lowdb": "^1.0.0",
    "macos-version": "^5.2.1",
    "mousetrap": "^1.6.3",
    "multiformats": "^9.7.1",
    "nanoid": "^3.3.11",
    "pino": "^5.13.2",
    "progress-stream": "^2.0.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-i18next": "^11.2.5",
    "react-query": "^3.39.0",
    "react-scroll": "^1.8.7",
    "react-swipeable": "^7.0.0",
    "reverse-line-reader": "^0.2.6",
    "rlp": "^2.2.2",
    "semver": "^7.7.2",
    "stackblur-canvas": "^2.5.0",
    "subleveldown": "^6.0.1",
    "tree-kill": "^1.2.2",
    "url-regex-safe": "^3.0.0",
    "xstate": "^4.37.1"
  },
  "overrides": {
    "@babel/runtime": "^7.26.10",
    "@babel/runtime-corejs3": "^7.26.10",
    "@tootallnate/once": "^3.0.1",
    "braces": "^3.0.3",
    "browserslist": "^4.26.3",
    "elliptic": {
      ".": "^6.6.1",
      "bn.js": "4.12.3"
    },
    "linkify-it": "^5.0.1",
    "loader-utils": "^2.0.4",
    "minimatch": "^3.1.5",
    "node-fetch": "^2.7.0",
    "object-path": "^0.11.8",
    "postcss": "^8.5.10",
    "secp256k1": "^5.0.1",
    "serialize-javascript": "^7.0.5",
    "shell-quote": "^1.8.3",
    "tar": "^7.5.13",
    "terser": "^4.8.1"
  },
  "prettier": {
    "trailingComma": "es5",
    "semi": false,
    "singleQuote": true,
    "bracketSpacing": false
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true,
    "leveldown@6.1.1": true,
    "sharp@0.34.5": true,
    "fsevents": false
  }
}
